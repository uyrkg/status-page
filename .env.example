# ============================================
# Status Page — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# Docker Compose reads these automatically.
#
#   cp .env.example .env
#   nano .env
#   docker-compose up -d
# ============================================

# --- App ---
# Public URL of this status page (used for email links)
APP_URL=http://localhost:8000

# --- SMTP / Email Alerts ---
# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP port (587 = TLS, 465 = SSL, 25 = unencrypted)
SMTP_PORT=587

# SMTP username (full email address)
SMTP_USER=your-email@gmail.com

# SMTP password
# IMPORTANT: For Gmail, use an App Password, not your real password.
#   1. Enable 2FA on your Google Account
#   2. Go to Security → App passwords
#   3. Create a new app password for "Mail"
#   4. Paste that 16-char password here
SMTP_PASSWORD=your-app-password-here

# From address for alert emails
SMTP_FROM=statuspage@yourdomain.com

# Use TLS (almost always true)
SMTP_TLS=true

# --- Monitoring ---
# Seconds between each health check run
CHECK_INTERVAL=60

# Days to retain check history before pruning
HISTORY_RETENTION_DAYS=30

# Suppress duplicate alerts within this window (minutes)
ALERT_COOLDOWN_MINUTES=5

# --- Admin ---
# Password for the admin panel (http://localhost:8000/admin)
# Set this to a strong password before deploying
ADMIN_PASSWORD=changeme